# -----------------------------------------------------------------------------
# Luminary / AC Buddy — example environment configuration
# Copy to `.env` and fill in real values for local development. In production
# (ENVIRONMENT != local) most secrets are pulled from Google Secret Manager —
# see app/config.py for the exact mapping.
# -----------------------------------------------------------------------------

# --- Runtime ----------------------------------------------------------------
# "local" (default) reads all secrets from env. Any other value reads from
# Google Secret Manager and requires GOOGLE_CLOUD_PROJECT.
ENVIRONMENT=local

# --- ElevenLabs -------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Required for inbound /webhook/elevenlabs in non-local environments.
# Local dev may leave this blank (verification will be skipped).
ELEVENLABS_WEBHOOK_SECRET=your-webhook-secret
# Primary agent id — kept for backward compat; falls back to MAYA if unset.
ELEVENLABS_AGENT_ID=your-agent-id
ELEVENLABS_AGENT_ID_MAYA=
ELEVENLABS_AGENT_ID_BARNABY=
ELEVENLABS_AGENT_ID_CONSULTANT=
ELEVENLABS_AGENT_ID_RUTGER=

# --- Google Cloud / Gemini --------------------------------------------------
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_API_KEY=your-google-api-key
# GCS bucket for research results, checkpoints, memory, knowledge graph.
GCS_RESULTS_BUCKET=

# --- Third-party model / data APIs -----------------------------------------
OPENAI_API_KEY=
GROK_API_KEY=
NEWSAPI_KEY=
ALPHA_VANTAGE_API_KEY=
CRUNCHBASE_API_KEY=

# --- Podcast voice IDs (ElevenLabs TTS) ------------------------------------
PODCAST_VOICE_ID_MAYA=
PODCAST_VOICE_ID_BARNABY=
PODCAST_VOICE_ID_CONSULTANT=
PODCAST_VOICE_ID_RUTGER=

# --- Deep research pipeline -------------------------------------------------
DEEP_MAX_STUDIES=6
DEEP_MAX_ROUNDS=3
DEEP_MAX_CONCURRENT_STUDIES=3

# --- Research plan confirmation --------------------------------------------
AUTO_PROCEED_QUICK=true
AUTO_PROCEED_STANDARD=false
AUTO_PROCEED_MAX_DURATION=120
REQUIRE_CONFIRMATION_DEEP=true

# --- Research time budgets (seconds) ---------------------------------------
RESEARCH_TIME_BUDGET_QUICK=180
RESEARCH_TIME_BUDGET_STANDARD=600
RESEARCH_TIME_BUDGET_DEEP=3600

# --- Notifications (watch_store) -------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@luminary.app

# --- Agent knowledge-base limit --------------------------------------------
# Max research documents attached to each ElevenLabs agent at a time.
# Oldest research docs are evicted when a new study is attached.
MAX_AGENT_KB_DOCS=3

# --- Blocking-IO executor sizing -------------------------------------------
# Default 16. Bump up if you increase DEEP_MAX_CONCURRENT_STUDIES.
LUMINARY_IO_POOL_SIZE=16
